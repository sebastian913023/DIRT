# ─────────────────────────────────────────────────────────────────────────────
# DIRT — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── STRIPE ────────────────────────────────────────────────────────────────────
# Get secret key from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get webhook secret by running: stripe listen --forward-to localhost:3001/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (already created — see CLAUDE.md for Stripe account details)
# Account: acct_1TQn8wAFQwdx1hs4  |  Product: prod_UXts68l10Z5Ms9
STRIPE_PRICE_ID=price_1TYo4xAFQwdx1hs4UQsNJQy9           # $10/mo standard
STRIPE_PRICE_ID_DISCOUNTED=price_1TYo5oAFQwdx1hs4Ocwzck2v # $5/mo referral

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── ADMIN PANEL ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=dirt_admin
# Generate with: node -e "const b=require('bcryptjs');b.hash('DirtAdmin2026!',12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=$2a$12$uW8cx1JbpHMRzF2GsWRAKe/BLu90E9GxHnrDMv9s1bn.NQfG5lIwi

# ── SESSION ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Leave blank locally (defaults to ./data/dirt.db)
# On Railway, set to: /data/dirt.db  (matches the volume mount at /data)
DB_PATH=

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PRODUCTION DOMAIN ─────────────────────────────────────────────────────────
# Leave blank for localhost development.
# In production (Railway), set to your Railway domain, e.g.:
# APP_URL=https://dirt-lab-production.up.railway.app
APP_URL=
