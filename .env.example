# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get from: stripe listen --forward-to localhost:3000/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Create with: stripe prices create ...  (see README)
STRIPE_PRICE_ID=price_...           # $10/mo standard
STRIPE_PRICE_ID_DISCOUNTED=price_... # $5/mo referral

# Your domain in production (leave blank for localhost)
APP_URL=
PORT=3000
